### Installation directory
set (CMAKE_INSTALL_PREFIX ${CMAKE_SOURCE_DIR})

include(Util)
set(LIBNEO_SOURCE_DIR "" CACHE PATH "Path to a local libneo checkout")
find_or_fetch(libneo)

### Path to the external libraries
set(FGSL_PATH "" CACHE PATH "Path to a built FGSL source tree")

if (NOT "${FGSL_PATH}" STREQUAL "")
    if (EXISTS "${FGSL_PATH}/.libs/libfgsl${CMAKE_STATIC_LIBRARY_SUFFIX}")
        message(STATUS "Using FGSL at ${FGSL_PATH}")
        add_custom_target(FGSL)
    else()
        message(STATUS "FGSL_PATH=${FGSL_PATH} does not contain a built FGSL library; building FGSL locally instead")
        set(FGSL_PATH "" CACHE PATH "Path to a built FGSL source tree" FORCE)
    endif()
endif()

if ("${FGSL_PATH}" STREQUAL "" AND DEFINED ENV{CODE} AND EXISTS "$ENV{CODE}/external/fgsl-1.6.0/.libs/libfgsl${CMAKE_STATIC_LIBRARY_SUFFIX}")
    message(STATUS "Using prebuilt FGSL in $CODE=" $ENV{CODE})
    add_custom_target(FGSL)

    set(FGSL_PATH $ENV{CODE}/external/fgsl-1.6.0/ CACHE PATH "FGSL path" FORCE)
endif()

if ("${FGSL_PATH}" STREQUAL "")
    if (DEFINED ENV{CODE})
        message(STATUS "No prebuilt FGSL found in $CODE=$ENV{CODE}; building FGSL locally")
    else()
        message(STATUS "Downloading and building external libraries")
    endif()
    include(fgsl)

    set(FGSL_PATH ${CMAKE_BINARY_DIR}/fgsl/src/FGSL CACHE PATH "FGSL path" FORCE)
endif()

set(FGSL_INC ${FGSL_PATH} CACHE PATH "FGSL include")
set(LIBFGSL ${FGSL_PATH}/.libs/libfgsl${CMAKE_STATIC_LIBRARY_SUFFIX} CACHE FILEPATH "FGSL lib")


### Directories of MPE
set(MPE_PATH /afs/itp.tugraz.at/opt/mpe/1.3.0/)

### NetCDF
find_program(NF_CONFIG "nf-config")

if (NF_CONFIG)
execute_process(COMMAND nf-config --includedir
                OUTPUT_VARIABLE NETCDFINCLUDE_DIR)
execute_process(COMMAND nc-config --libdir
				OUTPUT_VARIABLE NETCDFLIB_DIR)
execute_process(COMMAND nf-config --flibs
                OUTPUT_VARIABLE NETCDF_FLIBS)
else()
message(SEND_ERROR "nf-config not found. Please install libnetcdff-dev")
endif()

string(STRIP ${NETCDFINCLUDE_DIR} NETCDFINCLUDE_DIR)
string(STRIP ${NETCDFLIB_DIR} NETCDFLIB_DIR)
string(STRIP ${NETCDF_FLIBS} NETCDF_FLIBS)

message(STATUS "NetCDF include path: " ${NETCDFINCLUDE_DIR})
message(STATUS "NetCDF lib path: " ${NETCDFLIB_DIR})
message(STATUS "NetCDF Fortran libs: " ${NETCDF_FLIBS})

# Replace space by semicolon in the Fortran libs
string(REPLACE " " ";" NETCDF_FLIBS ${NETCDF_FLIBS})

include_directories(${NETCDFINCLUDE_DIR})
link_directories(${NETCDFLIB_DIR})
add_link_options(${NETCDF_FLIBS})
